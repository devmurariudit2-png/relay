# ── Required ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/reconciler?retryWrites=true&w=majority
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
# FRONTEND_URLS=https://your-app.vercel.app,https://staging.your-app.vercel.app
# ALLOW_ALL_ORIGINS=false

# ── Feature flags ─────────────────────────────────────────────────────────────
# EXCEPTION_THRESHOLD=10000   # Flag transactions above this as exceptions
