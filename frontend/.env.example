# Relay Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# The Base URL of your Supabase Project (e.g., https://your-project.supabase.co)
VITE_SUPABASE_URL=

# The Anon Key for your Supabase Project (Found in Project Settings > API)
VITE_SUPABASE_ANON_KEY=

# The URL of the Relay Node.js Backend API
# For local development: http://localhost:5000
# For production: https://your-render-app.onrender.com
VITE_API_URL=http://localhost:5000
